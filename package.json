{
  "name": "ecochineur",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Privacy-by-design Chrome MV3 extension for filtering Vinted without data collection.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "release:check": "npm run format:check && npm run lint && npm test && npm run build",
    "prepare": "husky",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint-staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@crxjs/vite-plugin": "^2.0.0-beta.27",
    "@eslint/js": "^9.29.0",
    "@types/chrome": "^0.0.326",
    "@types/node": "^22.10.2",
    "eslint": "^9.29.0",
    "git-cliff": "^2.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
